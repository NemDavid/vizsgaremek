<UserControl x:Class="AdminPanel.SRC.Views.PostsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.1*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="1.7*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource overcolorPanel}"
                CornerRadius="14"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBox Width="260"
                             Height="34"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             Padding="10,0"
                             BorderThickness="0"
                             Background="#2B2D42"
                             Foreground="White"
                             DockPanel.Dock="Left"/>

                    <Button Content="Frissítés"
                            Width="110"
                            Height="34"
                            Margin="12,0,0,0"
                            Command="{Binding RefreshCommand}"
                            DockPanel.Dock="Right"/>
                </DockPanel>

                <TextBlock Grid.Row="2"
                           Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource errorColor}"
                           FontSize="13"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <DataGrid Grid.Row="4"
                          ItemsSource="{Binding Posts}"
                          SelectedItem="{Binding SelectedPost, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          Background="Transparent"
                          Foreground="White"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#202335"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          ColumnHeaderStyle="{StaticResource DarkDataGridHeaderStyle}"
                          CellStyle="{StaticResource DarkDataGridCellStyle}"
                          RowStyle="{StaticResource DarkDataGridRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="90"/>
                        <DataGridTextColumn Header="Title" Binding="{Binding title}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Background="{StaticResource overcolorPanel}"
                CornerRadius="14"
                Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Poszt részletek"
                               Foreground="{StaticResource titleColor2}"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding SuccessMessage}"
                               Foreground="LightGreen"
                               Margin="0,12,0,0"
                               Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource errorColor}"
                               Margin="0,8,0,0"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                    <TextBlock Text="ID" Foreground="{StaticResource titleColor2}" Margin="0,20,0,0"/>
                    <TextBox Text="{Binding SelectedPostId}"
                             IsReadOnly="True"
                             Background="#1E2130"
                             Foreground="#AAAAAA"
                             BorderBrush="#3A3F5A"
                             Margin="0,5,0,12"/>

                    <TextBlock Text="Title" Foreground="{StaticResource titleColor2}"/>
                    <TextBox Text="{Binding SelectedPostTitle}"
                             IsReadOnly="True"
                             Background="#1E2130"
                             Foreground="White"
                             BorderBrush="#3A3F5A"
                             Margin="0,5,0,12"/>

                    <TextBlock Text="Content" Foreground="{StaticResource titleColor2}"/>
                    <TextBox Text="{Binding SelectedPostContent}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="120"
                             Background="#1E2130"
                             Foreground="White"
                             BorderBrush="#3A3F5A"
                             Margin="0,5,0,12"/>

                    <TextBlock Text="Létrehozva" Foreground="{StaticResource titleColor2}"/>
                    <TextBox Text="{Binding SelectedPostCreatedAt}"
                             IsReadOnly="True"
                             Background="#1E2130"
                             Foreground="#AAAAAA"
                             BorderBrush="#3A3F5A"
                             Margin="0,5,0,12"/>

                    <TextBlock Text="Módosítva" Foreground="{StaticResource titleColor2}"/>
                    <TextBox Text="{Binding SelectedPostUpdatedAt}"
                             IsReadOnly="True"
                             Background="#1E2130"
                             Foreground="#AAAAAA"
                             BorderBrush="#3A3F5A"
                             Margin="0,5,0,12"/>

                    <TextBlock Text="Kép" Foreground="{StaticResource titleColor2}" Margin="0,5,0,8"/>

                    <Border Height="220"
                            CornerRadius="12"
                            Background="#1E2130"
                            BorderBrush="#3A3F5A"
                            BorderThickness="1"
                            Margin="0,0,0,16">
                        <Grid>
                            <TextBlock Text="Nincs kép"
                                       Foreground="#AAAAAA"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding SelectedPostImage, Converter={StaticResource NullImageToVisibilityConverter}}"/>
                            <Image Source="{Binding SelectedPostImage}"
                                   Stretch="Fill"/>
                        </Grid>
                    </Border>

                    <Button Content="Poszt törlése"
                            Width="140"
                            Height="38"
                            Margin="0,0,0,20"
                            Command="{Binding DeletePostCommand}"/>

                    <TextBlock Text="Kommentek"
                               Foreground="{StaticResource titleColor2}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,10,0,10"/>

                    <DataGrid ItemsSource="{Binding Comments}"
                              SelectedItem="{Binding SelectedComment, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              BorderThickness="0"
                              Background="Transparent"
                              Foreground="White"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#202335"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              MinHeight="180"
                              ColumnHeaderStyle="{StaticResource DarkDataGridHeaderStyle}"
                              CellStyle="{StaticResource DarkDataGridCellStyle}"
                              RowStyle="{StaticResource DarkDataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="70"/>
                            <DataGridTextColumn Header="User" Binding="{Binding USER_ID}" Width="70"/>
                            <DataGridTextColumn Header="Komment" Binding="{Binding comment}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Content="Komment törlése"
                            Width="150"
                            Height="38"
                            Margin="0,12,0,0"
                            Command="{Binding DeleteCommentCommand}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>