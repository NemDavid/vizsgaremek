<UserControl x:Class="AdminPanel.SRC.Views.AdminsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.1*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="1.7*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource overcolorPanel}"
                CornerRadius="14"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBox Width="260"
                             Height="34"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             Padding="10,0"
                             BorderThickness="0"
                             Background="#2B2D42"
                             Foreground="White"
                             DockPanel.Dock="Left"/>

                    <Button Content="Frissítés"
                            Width="110"
                            Height="34"
                            Margin="12,0,0,0"
                            Command="{Binding RefreshCommand}"
                            DockPanel.Dock="Right"/>
                </DockPanel>

                <TextBlock Grid.Row="2"
                           Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource errorColor}"
                           FontSize="13"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <DataGrid Grid.Row="4"
                          ItemsSource="{Binding Admins}"
                          SelectedItem="{Binding SelectedAdmin, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          Background="Transparent"
                          Foreground="White"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#202335"
                          AlternationCount="2"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          ColumnHeaderStyle="{StaticResource DarkDataGridHeaderStyle}"
                          CellStyle="{StaticResource DarkDataGridCellStyle}"
                          RowStyle="{StaticResource DarkDataGridRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="70"/>
                        <DataGridTextColumn Header="Username" Binding="{Binding username}" Width="140"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding email}" Width="*"/>
                        <DataGridTextColumn Header="Role" Binding="{Binding role}" Width="90"/>
                        <DataGridTextColumn Header="Létrehozva" Binding="{Binding created_at}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Background="{StaticResource overcolorPanel}"
                CornerRadius="14"
                Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Admin részletek"
                               Foreground="{StaticResource titleColor2}"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding SuccessMessage}"
                               Foreground="LightGreen"
                               Margin="0,12,0,0"
                               Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource errorColor}"
                               Margin="0,8,0,0"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                    <TextBlock Text="ID" Foreground="{StaticResource titleColor2}" Margin="0,20,0,0"/>
                    <TextBox Text="{Binding SelectedId}"
                             IsReadOnly="True"
                             Background="#1E2130"
                             Foreground="#AAAAAA"
                             BorderBrush="#3A3F5A"
                             Margin="0,5,0,12"/>

                    <TextBlock Text="Username" Foreground="{StaticResource titleColor2}"/>
                    <TextBox Text="{Binding SelectedUsername}"
                             IsReadOnly="True"
                             Background="#1E2130"
                             Foreground="White"
                             BorderBrush="#3A3F5A"
                             Margin="0,5,0,12"/>

                    <TextBlock Text="Email" Foreground="{StaticResource titleColor2}"/>
                    <TextBox Text="{Binding SelectedEmail}"
                             IsReadOnly="True"
                             Background="#1E2130"
                             Foreground="White"
                             BorderBrush="#3A3F5A"
                             Margin="0,5,0,12"/>

                    <TextBlock Text="Role" Foreground="{StaticResource titleColor2}"/>
                    <TextBox Text="{Binding SelectedRole}"
                             IsReadOnly="True"
                             Background="#1E2130"
                             Foreground="White"
                             BorderBrush="#3A3F5A"
                             Margin="0,5,0,12"/>

                    <TextBlock Text="Létrehozva" Foreground="{StaticResource titleColor2}"/>
                    <TextBox Text="{Binding SelectedCreatedAt}"
                             IsReadOnly="True"
                             Background="#1E2130"
                             Foreground="#AAAAAA"
                             BorderBrush="#3A3F5A"
                             Margin="0,5,0,20"/>

                    <Border Background="#25283A"
                            CornerRadius="12"
                            Padding="16"
                            Visibility="{Binding IsOwner, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Owner panel"
                                       Foreground="{StaticResource titleColor2}"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="Cél user ID"
                                       Foreground="{StaticResource titleColor2}"
                                       Margin="0,15,0,0"/>

                            <DockPanel Margin="0,5,0,12">
                                <TextBox Text="{Binding TargetUserId, UpdateSourceTrigger=PropertyChanged}"
                                         Width="120"
                                         Height="34"
                                         VerticalContentAlignment="Center"
                                         Padding="10,0"
                                         Background="#1E2130"
                                         Foreground="White"
                                         BorderBrush="#3A3F5A"
                                         DockPanel.Dock="Left"/>

                                <Button Content="Adminná tétel"
                                        Width="130"
                                        Height="34"
                                        Margin="12,0,0,0"
                                        Command="{Binding PromoteToAdminCommand}"
                                        DockPanel.Dock="Left"/>

                                <Button Content="Ownerré tétel"
                                        Width="130"
                                        Height="34"
                                        Margin="12,0,0,0"
                                        Command="{Binding PromoteToOwnerCommand}"
                                        DockPanel.Dock="Left"/>
                            </DockPanel>

                            <Button Content="Kijelölt admin userré tétele"
                                    Width="220"
                                    Height="38"
                                    Command="{Binding DemoteToUserCommand}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>