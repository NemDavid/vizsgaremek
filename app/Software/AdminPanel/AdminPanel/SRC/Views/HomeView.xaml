<UserControl x:Class="AdminPanel.SRC.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource errorColor}"
                   FontSize="14"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

        <UniformGrid Grid.Row="4" Columns="3" HorizontalAlignment="Stretch">

            <Border Margin="0,0,15,0"
                    Padding="25"
                    CornerRadius="14"
                    Background="{StaticResource overcolorPanel}">
                <StackPanel>
                    <TextBlock Text="Felhasználók"
                               Foreground="{StaticResource titleColor2}"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding UsersCount}"
                               Foreground="White"
                               FontSize="42"
                               FontWeight="Bold"
                               Margin="0,15,0,0"/>
                </StackPanel>
            </Border>

            <Border Margin="0,0,15,0"
                    Padding="25"
                    CornerRadius="14"
                    Background="{StaticResource overcolorPanel}">
                <StackPanel>
                    <TextBlock Text="Posztok"
                               Foreground="{StaticResource titleColor2}"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding PostsCount}"
                               Foreground="White"
                               FontSize="42"
                               FontWeight="Bold"
                               Margin="0,15,0,0"/>
                </StackPanel>
            </Border>

            <Border Padding="25"
                    CornerRadius="14"
                    Background="{StaticResource overcolorPanel}">
                <StackPanel>
                    <TextBlock Text="Hirdetések"
                               Foreground="{StaticResource titleColor2}"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding AdsCount}"
                               Foreground="White"
                               FontSize="42"
                               FontWeight="Bold"
                               Margin="0,15,0,0"/>
                </StackPanel>
            </Border>

        </UniformGrid>
    </Grid>
</UserControl>