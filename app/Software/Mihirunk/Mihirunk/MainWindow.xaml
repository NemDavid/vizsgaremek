<Window x:Class="Mihirunk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Mihirunk" Height="1010" Width="585"
        MinHeight="1010"
        MinWidth="585">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Gombok Website/Admin nézet váltáshoz -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="10" x:Name="AdminButtons" Visibility="Collapsed">
            <Button Content="Website nézet" Margin="5" Click="BtnWebsiteView_Click"/>
            <Button Content="Admin nézet" Margin="5" Click="BtnAdminView_Click"/>
        </StackPanel>

        <!-- Fő tartalom -->
        <Grid Grid.Row="1" x:Name="MainContent">

            <!-- WebView2, alapból Website nézet -->
            <wv2:WebView2 x:Name="webView"/>

            <!-- Admin nézet, alapból rejtve -->
            <Grid x:Name="AdminView" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <!-- Menü -->
                    <ColumnDefinition Width="*"/>
                    <!-- Tartalom -->
                </Grid.ColumnDefinitions>

                <!-- Menü -->
                <StackPanel Grid.Column="0" Background="#EEE" x:Name="AdminMenu">
                    <Button Content="Felhasználók" Margin="5" Click="AdminMenu_Click"/>
                    <Button Content="Ads" Margin="5" Click="AdminMenu_Click"/>
                    <Button Content="Themes" Margin="5" Click="AdminMenu_Click"/>
                    <Button Content="Postok" Margin="5" Click="AdminMenu_Click"/>
                </StackPanel>

                <!-- Tartalom panel -->
                <ContentControl Grid.Column="1" x:Name="AdminContent" Background="White"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
